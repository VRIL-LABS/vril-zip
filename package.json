{
  "name": "@workspace/vril-zip",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VRIL-ZIP — provably lossless compression with the Schauberger φ-permutation pipeline. Container format VRZ1 with CRC32 integrity. Optional CVKDF-authenticated mode.",
  "exports": {
    ".": "./src/index.ts",
    "./cvkdf": "./src/cvkdf.ts",
    "./container": "./src/container.ts"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types test/*.test.mts",
    "bench": "node --experimental-strip-types bench/bench.mts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "1.5.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "5.6.3"
  }
}
